#!/bin/bash

dependencies=(git feh picom slop termite xorg-server abook alsa-card-profiles alsa-lib alsa-plugins alsa-utils dunst emacs exa ffmpeg ffmpegthumbnailer fzf imagemagick lxappearance-gtk3 maim mpc mpd mpv mupdf ncmpcpp neomutt neovim newsboat nitrogen obconf openbox pamixer poppler pulseaudio pulseaudio-alsa pulsemixer qutebrowser ranger rofi scrot sxiv tint2 transmission-cli transmission-gtk ttf-nerd-fonts-symbols urlscan w3m xautolock xclip xdg-user-dirs xdg-utils xdotool xf86-input-libinput xf86-video-intel xmobar xmonad xmonad-contrib xorg-font-util xorg-fonts-misc xorg-mkfontscale xorg-xinit xorg-xrandr xorg-xsetroot xorg-server-common xorg-server-devel xorg-setxkbmap xorg-xclipboard xorg-xdpyinfo xorg-xev xorg-xfontsel xorg-xinput xorg-xmodmap xorg-xprop xorg-xrandr xorg-xrdb xorg-xset xorg-xsetroot xorg-xwininfo xscreensaver youtube-dl zathura zathura-pdf-poppler zsh unzip ueberzug xcompmgr)

dependencies_aur=(awesome-git brave-dev-bin urlview nerd-fonts-iosevka vidir libxft-bgra)

clear

# Create a new user
read -p "New username:" username
sudo useradd -m $username
sudo passwd $username

# sudo pacman -Syu --noconfirm

# install_dependencies() {
#   sudo pacman -S --needed --noconfirm "$@"
# }


# install_dependencies "${dependencies[@]}"

# if command -v yay &> /dev/null
# then
# 	echo "Installing packages from AUR ..."
# else
# 	aur_tmp_dir=$(mktemp -d) && cd "$aur_tmp_dir" || exit 1
#   	git clone "https://aur.archlinux.org/yay.git" "$aur_tmp_dir"
#   	makepkg -sim --noconfirm
# fi
# yay -S --needed --noconfirm "${dependencies_aur[@]}"

echo "Copying dotfiles for new user"
{
	url="https://github.com/yrwq/dotfiles.git"
	temp_directory_dotfiles=$(mktemp -d)
  	git clone "$url" "$temp_directory_dotfiles"
  	sudo cp -rb "$temp_directory_dotfiles"/. /home/$username/
	walls="https://github.com/yrwq/walls.git"
  	sudo git clone "$walls" /home/$username/.wp
}

# finalize
{
  sudo chsh -s /usr/bin/zsh $username
  echo "${username} ALL=(ALL) NOPASSWD:ALL" | sudo tee /etc/sudoers.d/${username}
  sudo chown -R ${username} /home/${username}
}

echo "Installation finished, now you can login as ${username}."
