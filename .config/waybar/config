{
    "layer": "top",
    "position": "top",
    "height": 20,
    "width": 1280,

    "modules-left": [
        "river/tags"
    ],

    "modules-center": ["wlr/taskbar"],

    "modules-right": [
        "pulseaudio",
        "cpu",
        "memory",
        "network",
        "clock",
    ],

    "wlr/taskbar": {
        "on-click": "minimize-raise"
    },

    "clock": {
        "timezone": "Europe/Budapest",
        "format": "{:%H:%M}",
        "format-alt": "{:%a %b %d}"
    },

    "cpu": {
        "interval": 30,
        "format": " {usage}%",
        "max-length": 10
    },

    "memory": {
        "interval": 30,
        "format": " {used:0.1f}G"
    },

    "network": {
        "format-ethernet": "{ifname}: {ipaddr}/{cidr}",
        "format-disconnected": " No network",
        "interval": 1
    },

    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume}",
        "format-muted": "  {volume}",
        "format-source-muted": "",
        "on-click": "pactl set-sink-mute 0 toggle",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
    },
}

