set font "Iosevka Custom 14"

set window-title-home-tilde true
set statusbar-basename true
set selection-clipboard clipboard

set sandbox none
set statusbar-h-padding 0
set statusbar-v-padding 0
set page-padding 1
set statusbar-basename "true"

map i recolor

set default-bg "#282828"
set default-fg "#cdc1c1"

set statusbar-fg "#282828"
set statusbar-bg "#cdc1c1"

set inputbar-bg "#282828"
set inputbar-fg "#cdc1c1"

set notification-bg "#282828"
set notification-fg "#cdc1c1"

set notification-error-bg "#282828"
set notification-error-fg "#db7464"

set notification-warning-bg "#282828"
set notification-warning-fg "#db7464"

set highlight-color "#dbd560"
set highlight-active-color "#69b2d6"

set completion-bg "#282828"
set completion-fg "#69b2d6"

set completion-highlight-fg "#cdc1c1"
set completion-highlight-bg "#69b2d6"

set recolor-lightcolor "#282828"
set recolor-darkcolor "#cdc1c1"

set recolor "true"
set recolor-keephue "true"
