set font "Iosevka Custom 14"

set window-title-home-tilde true
set statusbar-basename true
set selection-clipboard clipboard

set sandbox none
set statusbar-h-padding 0
set statusbar-v-padding 0
set page-padding 1
set statusbar-basename "true"

map i recolor

set default-bg "#1d2021"
set default-fg "#d4be98"

set statusbar-fg "#1d2021"
set statusbar-bg "#d4be98"

set inputbar-bg "#1d2021"
set inputbar-fg "#d4be98"

set notification-bg "#1d2021"
set notification-fg "#d4be98"

set notification-error-bg "#1d2021"
set notification-error-fg "#ea6962"

set notification-warning-bg "#1d2021"
set notification-warning-fg "#ea6962"

set highlight-color "#e78a4e"
set highlight-active-color "#7daea3"

set completion-bg "#1d2021"
set completion-fg "#7daea3"

set completion-highlight-fg "#d4be98"
set completion-highlight-bg "#7daea3"

set recolor-lightcolor "#1d2021"
set recolor-darkcolor "#d4be98"

set recolor "true"
set recolor-keephue "true"
