[colors]
    foreground = "#947e68"

[global]
    monitor = 0
    follow = keyboard
    geometry = "300x8-18+20"    

    indicate_hidden = yes
    shrink = true
    transparency = 1
    notification_height = 3
    separator_height = 0
    padding = 24
    horizontal_padding = 24
    frame_width = 2
    outer_frame_width = 5
    corner_radius = 0

    outer_frame_color = "#322b28"
    separator_color = auto
    sort = yes
    idle_threshold = 120

    font = Dina 8
    line_height = 1

    markup = full

    format = "%s\n%b"
    alignment = center
    show_age_threshold = 60
    word_wrap = true
    ellipsize = middle
    ignore_newline = false
    stack_duplicates = true
    hide_duplicate_count = true
    show_indicators = true

    icon_position = left
    max_icon_size = 80
    #icon_path = /usr/share/icons/PineCone/48x48/status/:/usr/share/icons/PineCone/48x48/apps/:/usr/share/icons/PineCone/48x48/devices/

    ### History ###
    sticky_history = yes
    history_length = 20

    ### Misc/Advanced ###
    dmenu = /usr/bin/st -e fzf:
    browser = linkhandler
    always_run_script = false
    title = Dunst
    class = Dunst
    startup_notification = false
    force_xinerama = false

[experimental]
    per_monitor_dpi = false

[shortcuts]
    close = shift+space
    close_all = ctrl+shift+space
    #context = ctrl+shift+period
    history = ctrl+period

[urgency_low]
    background = "#201e1a"
    frame_color = "#6a7253"
    timeout = 3

[urgency_normal]
    background = "#201e1a"
    frame_color = "#7e5d3c"
    timeout = 5

[urgency_critical]
    background = "#201e1a"
    frame_color = "#6d413b"
    timeout = 0
