 [global]
    font = Iosevka Custom 10
    follow = mouse
    geometry = "270x50-19+50"
    #geometry = "303x80-19+24"
    indicate_hidden = no
    shrink = yes
    transparency = 0
    notification_height = 0
    separator_height = 4
    padding = 16
    horizontal_padding = 14
    frame_width = 2
    sort = yes
    idle_threshold = 120
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = false
    hide_duplicate_count = false
    show_indicators = no
    icon_position = left
    max_icon_size = 80
    icon_folders = /usr/share/icons/gnome/16x16/status/:/usr/share/icons/gnome/16x16/devices/
    sticky_history = yes
    history_length = 20
    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/qutebrowser
    always_run_script = true
    title = Dunst
    class = Dunst
    startup_notification = false
    force_xinerama = false

frame_color = "#8ea594"
separator_color = "#8ea594"

[base16_low]
    msg_urgency = low
    background = "#1f1d29"
    foreground = "#ffffff"
    timeout = 3

[base16_normal]
    msg_urgency = normal
    background = "#403c58"
    foreground = "#faebd7"
    timeout = 5

[base16_critical]
    msg_urgency = critical
    background = "#6f6e85"
    foreground = "#faebd7"
    timeout = 15
