[colors]
bg = ${xrdb:background}
bg-alt = ${xrdb:color0}
fg = ${xrdb:foreground}
clr1 = ${crdb:color1}

[bar/main]
width = 100%
height = 30
offset-x = 0
offset-y = 0
padding-right = 2
padding-left = 2
background = ${colors.bg}
foreground = ${colors.fg}
font-0 = Iosevka Custom:pixelsize=10;1
font-1 = Iosevka Nerd Font:pixelsize=10;1
separator = " "
line-size = 2
modules-left = title
modules-center = ewmh
modules-right = downspeed sep disk sep pkg sep pulseaudio sep date
override-redirect = true
tray-position = right


;;
;; separator
;;

[module/sep]
type = custom/text
content = "  "
content-background = ${colors.bg}
content-font = 2

;;
;; date
;;

[module/date]
type = internal/date
interval = 5
label-foreground = ${colors.fg}
label-background = ${colors.bg}
time = " %H:%M"
label =  %time%

;;
;; title
;;

[module/title]
type = internal/xwindow
label = %title%
label-maxlen = 50

;;
;; pulseaudio
;;

[module/pulseaudio]
type = internal/pulseaudio
format-volume = <label-volume>
label-volume =  %percentage%
label-volume-foreground = ${colors.fg}
label-muted = ﳌ %percentage%
label-muted-foreground = ${colors.bg-alt}

;;
;; ewmh
;;

[module/ewmh]
type = internal/xworkspaces
pin-workspaces = false
enable-click = true
enable-scroll = false

label-active = 
label-active-foreground = ${colors.fg}
label-active-underline =  ${colors.bg}
label-active-padding = 1

label-occupied = 
label-occupied-foreground = ${colors.fg}
label-occupied-underline = ${colors.bg}
label-occupied-padding = 1

label-urgent = 
label-urgent-foreground = ${colors.fg}
label-urgent-underline = ${colors.bg}
label-urgent-padding = 1

label-empty = 
label-empty-foreground = ${colors.fg}
label-empty-underline = ${colors.bg}
label-empty-padding = 1

;;
;; pkgs
;;

[module/pkg]
type = custom/script
exec = pacman -Qu | wc -l
interval = 1800
label =  %output%
format-foreground = ${colors.fg}
format-background = ${colors.bg}

;;
;; disk
;;

[module/disk]
type = internal/fs
mount-0 = /
interval = 1800
format-mounted = <label-mounted>
label-mounted =  %used% / %total%

;;
;; network down
;;

[module/downspeed]
type = internal/network
interface = enp1s0
label-connected = "%downspeed:7%"
format-connected = <label-connected>
format-connected-prefix = " "
format-connected-prefix-foreground = ${colors.fg}
format-connected-foreground = ${colors.fg}
format-connected-background = ${colors.bg}

;;
;; weather
;;

[module/weather]
type = custom/script
exec = curl -Ss wttr.in/Pécs?format=j1 | jq '.current_condition[].temp_C' | sed 's/"//g'
interval = 1800
label = 摒  %output%糖
format-foreground = ${colors.fg}
format-background = ${colors.bg}

;;
;; polywins
;;

[module/polywins]
type = custom/script
exec = ~/.config/polybar/scripts/polywins.sh 2>/dev/null
format = <label>
label = %output%
label-padding = 2
tail = true
