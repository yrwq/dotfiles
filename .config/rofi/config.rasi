configuration{
	display-run: "´äá ";
	display-drun: "´äá ";
	display-window: "´ïÉ  ";
	font: "Iosevka Custom 10";
	modi: "window,run,drun";
}

* {
  /* Size */
  /* Sidebox */
  mode-switcher-padding: 0 0 50% 0;
  button-margin: 0.5em;
  button-padding: 1.5em 2em;
  button-selected-border: 0 0 0 0.3em;
  /* Mainbox */
  mainbox-padding: @button-margin; /* 0.5em */
  inputbar-padding: @button-margin; /* 0.5em */
  element-margin: 0.3em;
  element-padding: 1em;

  /* Color */

  bg: rgba ( 46, 52, 64, 100 % );
  sel-bg: rgba ( 59, 66, 82, 100 % );
  fg: rgba ( 229, 233, 240, 100 % );

  background-color: @bg;
  text-color: @fg;
}

#window {
  location: center;
  padding: 2em;
  border: 3px;
  border-color: @sel-bg;
}

#listview {
  layout: vertical;
  padding: 2em;
}

#element {
  padding: 0.5em;
}

#element.selected {
  background-color: @sel-bg; 
}