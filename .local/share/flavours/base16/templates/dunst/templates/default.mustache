frame_color = "#{{base05-hex}}"
separator_color = "#{{base05-hex}}"

[base16_low]
    msg_urgency = low
    background = "#{{base00-hex}}"
    foreground = "#{{base05-hex}}"
	timeout = 3

[base16_normal]
    msg_urgency = normal
    background = "#{{base01-hex}}"
    foreground = "#{{base05-hex}}"
	timeout = 5

[base16_critical]
    msg_urgency = critical
    background = "#{{base05-hex}}"
    foreground = "#{{base00-hex}}"
	timeout = 15
