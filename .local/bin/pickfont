#! /bin/sh

command -v "st" >"/dev/null" || exit 1

findfont () {
    fc-list \
        | grep -v -i "nerd" \
        | cut -d ":" -f2 \
        | cut -d "," -f1 \
        | uniq \
        | sort -u
    }

font="$(findfont | rofi -dmenu -i)"
[ -z "$font" ] && exit 1

setsid -f st -f "$font:pixelsize=16:antialias=false" >"/dev/null" 2>&1
