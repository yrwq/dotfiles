#!/usr/bin/env python
import sys
import getopt
import requests
from bs4 import BeautifulSoup

URL = "https://www.prokerala.com/astrology/horoscope/?sign=virgo"
TMR = "https://www.prokerala.com/astrology/horoscope/?sign=virgo&day=tomorrow"

argumentList = sys.argv[1:]

options = "dt"

long_options = [ "tomorrow", "today" ]

try:
    # Parsing argument
    arguments, values = getopt.getopt(argumentList, options, long_options)

    # checking each argument
    for currentArgument, currentValue in arguments:

        if currentArgument in ("-d", "--today"):
            page = requests.get(URL)
            soup = BeautifulSoup(page.text, 'html.parser')
            contents = soup.find_all('div', class_='horoscope-panel')
            print(contents[0].p.text)

        elif currentArgument in ("-t", "--tomorrow"):
            page = requests.get(TMR)
            soup = BeautifulSoup(page.text, 'html.parser')
            contents = soup.find_all('div', class_='horoscope-panel')
            print(contents[0].p.text)
        else:
            print("Unknown")

except getopt.error as err:
    print(str(err))
