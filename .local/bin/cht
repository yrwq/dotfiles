#!/bin/sh

#
# cht - change theme
# requires feh, libnotify

reset(){
    _wm=$(wmctrl -m | grep "Name:" | awk '{print $2}')
    case $_wm in
        awesome)
            _running=$(pidof awesome)
            [ $_running ] && echo 'awesome.restart()' | awesome-client
        ;;
        bspwm)
            _running=$(pidof bspwm)
            [ $_running ] && bspwm restart
        ;;
    esac
}

apply(){
    xrdb $_clr
    feh --bg-fill $_wp
}

# arguments
case "$1" in
    -r)
        _clr=$(shuf -n1 -e ~/.clr/*)
        _wp=$(shuf -n1 -e ~/.wp/*)
        apply
        sleep 1
        wait
        reset
    ;;
esac

_shortwp=$(echo $_wp | sed "s@.*/@@" | sed "s/.jpg//g" | sed "s/.png//g" )
_shortclr=$(echo $_clr | sed "s@.*/@@")

wait
noti "Theme changed" "Theme: ${_shortclr} \nWp: ${_shortwp}"
