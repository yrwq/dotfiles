#!/usr/bin/env bash
#
# Theme changer

rand=false
flavours=true

# get current window manager
wm=$(wmctrl -m | grep "Name:" | awk '{print $2}')

# wallpaper
wp=$(shuf -e -n1 ~/.wp/*)
short_wp=$(echo $wp | sed "s|/home/$USER/.wp/||g" | sed 's/.png//g' )

while getopts 'rc' flag; do
    case "${flag}" in
	f)
	    flavours='true'
	    rand='false'
	    choose='false'
	    ;;
        r)
            rand='true'
            choose='false'
	    flavours='false'
	    ;;
    esac
done

if [ $rand = 'true' ]; then
    theme=$(flavours list | sed 's/ / \n/g' | sort -R |  head -n1)
fi

if [ $flavours = 'true' ]; then
    theme=$(flavours list | sed 's/ / \n/g' | rofi -dmenu)
fi

[[ -z "$theme" ]] && { exit 1; }

apply(){
    flavours apply $theme
    xrdb ~/.Xresources
}

restart(){
    case $wm in
	awesome)
	    echo 'awesome.restart()' | awesome-client
	    ;;
	xmonad)
	    pkill dunst
	    dunst &
	    xmonad --restart
	    ;;
    esac
    feh --bg-scale $wp
    pkill emacs
    emacs --daemon &
}

apply
restart

notify-send "Theme changed!" "Theme: ${theme} \nWallpaper: ${short_wp}"
