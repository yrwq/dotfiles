#!/usr/bin/env bash
#
# Theme changer

rand=false
flavours=true

themes_path="$HOME/xfiles"
wp_path="$HOME/.wp"

while getopts 'rc' flag; do
    case "${flag}" in
		f)
			flavours='true'
			rand='false'
			choose='false'
			;;
        r)
            rand='true'
            choose='false'
			flavours='false'
			;;
    esac
done

if [ $rand = 'true' ]; then
	theme=$(flavours list | sed 's/ / \n/g' | grep -v light | sort -R |  head -n1)
fi

if [ $flavours = 'true' ]; then
	theme=$(flavours list | sed 's/ / \n/g' | grep -v light | rofi -dmenu)
fi

[[ -z "$theme" ]] && { exit 1; }
flavours apply $theme
xrdb ~/.Xresources

echo 'awesome.restart()' | awesome-client
cat ~/.config/Lightcord_BD/themes/style.css | xclip -sel clip

wp=$(shuf -e -n1 ~/.wp/*)
feh --bg-scale $wp
short_wp=$(echo $wp | sed "s|/home/$USER/.wp/||g" | sed 's/.png//g' )

notify-send "Successfully changed theme." "Theme: ${theme} \nWallpaper: ${short_wp}"

# nitrogen --restore
