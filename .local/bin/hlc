#!/usr/bin/env bash

hc() { "${herbstclient_command[@]:-herbstclient}" "$@" ;}

val=10
frame_gap=$(hc get frame_gap)
window_gap=$(hc get window_gap)

case $1 in
    # frame gap
    -fg)
        case $2 in
            "i"*)
                final=$(bc <<< $frame_gap+$val)
                hc set frame_gap $final
            ;;
            "d"*)
                final=$(bc <<< $frame_gap-$val)
                hc set frame_gap $final
            ;;
        esac
    ;;
    # window gap
    -wg)
        case $2 in
            "i"*)
                final=$(bc <<< $window_gap+$val)
                hc set window_gap $final
            ;;
            "d"*)
                final=$(bc <<< $window_gap-$val)
                hc set window_gap $final
            ;;
        esac
    ;;
    # volume
    -vol)
        get_vol="$(pamixer --get-volume)"
        case $2 in
            "i"*)
                final=$(bc <<< $get_vol+5)
                pamixer --set-volume $final
                dunstctl close-all
                notify-send -u low " $final"
            ;;
            "d"*)
                final=$(bc <<< $get_vol-5)
                pamixer --set-volume $final
                dunstctl close-all
                notify-send -u low " $final"
            ;;
        esac
    ;;
    # select tag
    -st)
        case $2 in
            # next
            "n"*)
                hc use_index +1 --skip-visible
                dunstctl close-all
                notify-send -u low "$(hc attr tags.focus.name)"
            ;;
            # prev
            "p"*)
                hc use_index -1 --skip-visible
                dunstctl close-all
                notify-send -u low "$(hc attr tags.focus.name)"
            ;;
            # focus index
            "f"*)
                hc use_index $3
                dunstctl close-all
                notify-send -u low "$(hc attr tags.focus.name)"
        esac
    ;;
    # save state
    -ss)
        hc complete 1 use |
        while read tag ; do
            echo -n "$tag: "
            hc dump "$tag"
        done
    ;;
    # load state
    -ls)
        while read line ; do
            tag="${line%%: *}"
            tree="${line#*: }"
            hc add "$tag"
            hc load "$tag" "$tree"
        done
    ;;
    -m)
        case $2 in
            "next") mpc next ;;
            "prev") mpc prev ;;
            "tog"*) mpc toggle ;;
        esac
    ;;
esac
