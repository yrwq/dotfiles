#!/bin/sh

#
# clr - color picker
# Requires: https://github.com/ym1234/colorpicker
# libnotify, wmctrl, imagemagick, xclip

clr_path="/tmp/color.png"

color=$(colorpicker -od)

if [[ -f "$clr_path" ]]; then
    rm -rf $clr_path
fi

convert -size 100x100 xc:${color} $clr_path
wait

notify-send -a colorpicker "${color}"

echo $color | xclip -sel clip
