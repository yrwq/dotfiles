#!/bin/sh

#
# clr - color picker
# Requires: https://github.com/ym1234/colorpicker
# libnotify, wmctrl, imagemagick, xclip

clr_path="/tmp/color.png"

color=$(colorpicker -od)

if [[ -f "$clr_path" ]]; then
    rm -rf $clr_path
fi

convert -size 100x100 xc:${color} $clr_path
wait

_wm=$(wmctrl -m | grep "Name:" | awk '{print $2}')

case $_wm in
    awesome)
        awesome-client "
        naughty = require('naughty')
        naughty.notify({
        image='$clr_path',
        title='$color'
        })
        "
        ;;
    *)
        notify-send -i $clr_path "${color}"
        ;;
esac

echo $color | xclip -sel clip
