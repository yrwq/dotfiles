#!/bin/sh

# If transmission-daemon is running, will ask to kill, else will ask to start.

if pidof transmission-daemon >/dev/null ;
then
	[ "$(printf "Yes\\nNo" | rofi -dmenu -i -p "Turn off transmission-daemon?")" = "Yes" ] && killall transmission-da && notify-send "transmission-daemon disabled."
else
	[ "$(printf "Yes\\nNo" | rofi -dmenu -i -p "Turn on transmission daemon?")" = "Yes" ] && transmission-daemon && notify-send "tranmission-daemon enabled."
fi
