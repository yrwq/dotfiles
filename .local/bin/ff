#!/usr/bin/env bash
#
#

fix=" "
bold="$(tput bold)"
red="$(tput setaf 1)"
violet="$(tput setaf 5)"
reset="$(tput sgr0)"
cr="${reset}"
c0="${reset}${bold}"

## Output

kitten(){
cat <<EOF
${c0}${red}
    /\_____/\   $fix
   /  o   o  \  $fix
  ( ==  ^  == ) $fix
   )         (
  (           )
 ( (  )   (  ) )
(__(__)___(__)__)
${reset}
EOF
}

write(){
cat <<EOF
${c0}${red}
  ______________________________
 / \                             \. $fix
|   |                            |. $fix
 \_ |                            |. $fix
    |                            |.
    |                            |.
    |                            |.
    |                            |.
    |                            |.
    |                            |.
    |                            |.
    |                            |.
    |                            |.
    |                            |.
    |                            |.
    |   _________________________|___
    |  /                            /.
    \_/dc__________________________/. $fix
${reset}
EOF
}

case "$@" in
	cat)
		kitten
	;;
	write)
		write
	;;
esac
