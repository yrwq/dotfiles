#!/bin/lua

-- simple script to update my dotfiles

-- function to add a new pair to the table
function add_copy(orig_copy_table, to_copy_table, key, value)
    table.insert(orig_copy_table, key)
    to_copy_table[key] = value
end

-- function to delete given path or file
function del(path)
    io.popen("rm -rf " .. path)
end

-- function to copy source path or file to destination
function copy(src, dest)
    io.popen("cp -r " .. src .. " " .. dest)
end

function make_dir(path)
    io.popen("mkdir -p " .. path)
end

-- create tables
orig_copy_table = {}
to_copy_table = {}

dot_dir = "~/dev/dotfiles/"

-- home directory

-- zprofile
add_copy(orig_copy_table, to_copy_table,
    "~/.zprofile", dot_dir .. ".zprofile")

-- xresources
add_copy(orig_copy_table, to_copy_table,
    "~/.Xresources", dot_dir .. ".Xresources")

-- xinitrc
add_copy(orig_copy_table, to_copy_table,
    "~/.xinitrc", dot_dir .. ".xinitrc")

-- gitconfig
add_copy(orig_copy_table, to_copy_table,
    "~/.gitconfig", dot_dir .. ".gitconfig")

-- scripts
add_copy(orig_copy_table, to_copy_table,
    "~/.local/bin", dot_dir .. ".local/bin")

-- fonts
add_copy(orig_copy_table, to_copy_table,
    "~/.local/share/fonts", dot_dir .. ".local/share")

-- awesome
add_copy(orig_copy_table, to_copy_table,
    "~/.config/awesome", dot_dir .. ".config")

-- discocss
add_copy(orig_copy_table, to_copy_table,
    "~/.config/discocss", dot_dir .. ".config")

-- discocss
add_copy(orig_copy_table, to_copy_table,
    "~/.config/dunst", dot_dir .. ".config")

-- fontconfig
add_copy(orig_copy_table, to_copy_table,
    "~/.config/fontconfig", dot_dir .. ".config")

-- lf
add_copy(orig_copy_table, to_copy_table,
    "~/.config/lf", dot_dir .. ".config")

-- mpd
add_copy(orig_copy_table, to_copy_table,
    "~/.config/mpd/mpd.conf", dot_dir .. ".config/mpd")

-- mpv
add_copy(orig_copy_table, to_copy_table,
    "~/.config/mpv", dot_dir .. ".config")

-- ncmpcpp
add_copy(orig_copy_table, to_copy_table,
    "~/.config/ncmpcpp/config", dot_dir .. ".config/ncmpcpp")
add_copy(orig_copy_table, to_copy_table,
    "~/.config/ncmpcpp/bindings", dot_dir .. ".config/ncmpcpp")

-- rofi
add_copy(orig_copy_table, to_copy_table,
    "~/.config/rofi", dot_dir .. ".config")

-- yafetch
add_copy(orig_copy_table, to_copy_table,
    "~/.config/yafetch", dot_dir .. ".config")

-- zathura
add_copy(orig_copy_table, to_copy_table,
    "~/.config/zathura", dot_dir .. ".config")

-- herbstluftwm
add_copy(orig_copy_table, to_copy_table,
    "~/.config/herbstluftwm", dot_dir .. ".config")

-- zsh
add_copy(orig_copy_table, to_copy_table,
    "~/.config/zsh/.zshrc", dot_dir .. ".config/zsh")

-- user-dirs
add_copy(orig_copy_table, to_copy_table,
    "~/.config/user-dirs.dirs", dot_dir .. ".config")

-- files to delete before copying
deletes = {
    dot_dir .. ".wp",
    dot_dir .. ".local/bin",
    dot_dir .. ".local/share/fonts",
    dot_dir .. ".config/awesome",
    dot_dir .. ".config/mpd",
    dot_dir .. ".config/ncmpcpp",
    dot_dir .. ".config/rofi"
}

make_dirs = {
    dot_dir .. ".config/mpd",
    dot_dir .. ".config/ncmpcpp"
}

for _, file in ipairs(deletes) do
    del(file)
end

for _, file in ipairs(make_dirs) do
    make_dir(file)
end

-- iterate through table and copy each file to given the path
for _, k in ipairs(orig_copy_table) do
    copy(k, to_copy_table[k])
end

