#!/bin/sh
#
# Sync dotfiles

dotdir="$HOME/dev/dotfiles/"
dotconf="$HOME/dev/dotfiles/.config"
dotbin="$HOME/dev/dotfiles/.local/bin"
dotshare="$HOME/dev/dotfiles/.local/share"

confdir="$HOME/.config"
bindir="$HOME/.local/bin"
sharedir="$HOME/.local/share"

# config
rm -rf $dotconf/*
mkdir $dotconf/newsboat
mkdir $dotconf/nvim
mkdir $dotconf/qutebrowser
mkdir $dotconf/ncmpcpp

cp $confdir/awesome $dotconf/ -r
cp $confdir/discocss $dotconf/ -r
cp $confdir/flavours $dotconf/ -r
cp $confdir/lf $dotconf/ -r
cp $confdir/mpv $dotconf/ -r
cp $confdir/newsboat/config $dotconf/newsboat -r
cp $confdir/newsboat/urls-sample $dotconf/newsboat/urls
cp $confdir/nvim/init.vim $dotconf/nvim/ -r
cp $confdir/qutebrowser/config.py $dotconf/qutebrowser -r
cp $confdir/ranger $dotconf/ -r
cp $confdir/rofi $dotconf/ -r
cp $confdir/shell $dotconf/ -r
cp $confdir/termite $dotconf/ -r
cp $confdir/zsh $dotconf/ -r
cp $confdir/directories $dotconf/ -r
cp $confdir/mimeapps.list $dotconf/ -r
cp $confdir/shortcutrc $dotconf/ -r
cp $confdir/user-dirs.dirs $dotconf/ -r
cp $confdir/zshnameddirrc $dotconf/ -r
cp $confdir/gtk-3.0 $dotconf/ -r
cp $confdir/dunst $dotconf/ -r
cp $confdir/ncmpcpp/config $dotconf/ncmpcpp -r
cp $confdir/ncmpcpp/bindings $dotconf/ncmpcpp -r
cp $confdir/polybar $dotconf/ -r
cp $confdir/picom.conf $dotconf/ -r
cp $confdir/fontconfig $dotconf/ -r

# local
rm -rf $dotshare/*
rm -rf $dotdir/.local/bin

cp $sharedir/flavours $dotshare/ -r
cp $sharedir/applications $dotshare/ -r
cp $sharedir/fonts $dotshare/ -r
cp $sharedir/chars.csv $dotshare/ -r
cp $bindir $dotdir/.local -r
rm -rf $dotbin/ytw

# home
rm -rf $dotdir/.emacs.d
rm -rf $dotdir/.xmonad
mkdir -p $dotdir/.emacs.d/themes
mkdir -p $dotdir/.xmonad

cp $HOME/.emacs.d/init.el $dotdir/.emacs.d/ -r
cp $HOME/.emacs.d/themes/base16-main-theme.el $dotdir/.emacs.d/themes/ -r
cp $HOME/.xmonad/xmonad.hs $dotdir/.xmonad/ -r
cp $HOME/.zprofile $dotdir/ -r
cp $HOME/.Xresources $dotdir/ -r
cp $HOME/.xprofile $dotdir/ -r
cp $HOME/.xinitrc $dotdir/ -r
cp $HOME/.gitconfig $dotdir/ -r
