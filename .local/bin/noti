#!/bin/sh

#
# noti - notification
#

image=0
urgency=0
wm=$(wmctrl -m | grep "Name:" | awk '{print $2}')

_help(){
cat <<EOF

noti "title" "message" "image path"

EOF
}

awesome-client "
local naughty = require('naughty')
naughty.notify({
    image='$3',
    title='$1',
    message='$2'
})
"
exit 1
