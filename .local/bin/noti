#!/bin/sh

wm=$(wmctrl -m | grep "Name:" | awk '{print $2}')

urgency(){
	case $wm in
	awesome)
		awesome-client "
			naughty = require('naughty')
			naughty.notify({
			preset='low',
			timeout=3,
			title='low'})

			naughty.notify({
			preset='normal',
			timeout=3,
			title='normal'})

			naughty.notify({
			preset='critical',
			timeout=3,
			title='critical'})

		"
		;;
	*)
		notify-send -u "low" "low"
		notify-send -u "normal" "normal"
		notify-send -u "critical" "critical"
		;;
esac

case "$@" in
	urg)
		urgency
		;;
esac
