#!/bin/sh

#
# noti - notification
#


wm=$(wmctrl -m | grep "Name:" | awk '{print $2}')


_help(){
cat <<EOF

noti "title here" "message here" "image path here"

EOF
}
if [[ -e $1 ]]; then
    _help
else
    case $wm in
    awesome)
        awesome-client "
            naughty = require('naughty')
            naughty.notify({
                urgency='normal',
                title='$1',
                message='$2',
                image='$3'
            })
        "
    ;;
    *)
        notify-send -u "normal" "normal"
    ;;
    esac
fi
