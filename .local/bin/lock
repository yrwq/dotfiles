#!/bin/sh

#
# lock - auto lock screen after x minutes
# I have this script run after 10  mins of inactivity (see ~/.xinitrc)

# get current window manager
wm=$(wmctrl -m | grep "Name:" | awk '{print $2}')

awesome_lock(){
    awesome-client "
    local lock_screen = require('module.lockscreen')
    lock_screen.init()
    lock_screen_show()
"
}

other_lock(){
    scrot /tmp/i3lock.png
    convert /tmp/i3lock.png -blur 2x8 /tmp/i3lock.png
    i3lock -i /tmp/i3lock.png
    rm /tmp/i3lock.png
}

# Handle window managers
case $wm in
    awesome)
        awesome_lock
    ;;
    *)
        other_lock
    ;;
esac
