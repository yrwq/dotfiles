#!/bin/bash

#
# yt - infinite loop youtube download
#

while :
do
    clear
    read -rp "URL:" url
    youtube-dl $url \
        --add-metadata --metadata-from-title "%(artist)s - %(title)s" --embed-thumbnail \
        --extract-audio --audio-format mp3 --audio-quality 0 --prefer-ffmpeg \
        --youtube-skip-dash-manifest --ignore-errors --restrict-filenames
    notify-send "  YouTube" "Download finished!"
done
