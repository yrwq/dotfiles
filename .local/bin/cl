#!/bin/bash
#
# Colors.

f=3 b=4
for j in f b; do
  for i in {0..7}; do
    printf -v $j$i %b "\e[${!j}${i}m"
  done
done
d=$'\e[1m'
t=$'\e[0m'
v=$'\e[7m'

block(){
cat << EOF

 $f1███$d██$t $f2███$d██$t $f3███$d██$t $f4███$d██$t $f5███$d██$t $f6███$d██$t
 $f1███$d██$t $f2███$d██$t $f3███$d██$t $f4███$d██$t $f5███$d██$t $f6███$d██$t
 $ft███$d$f7██$t $ft███$d$f7██$t $ft███$d$f7██$t $ft███$d$f7██$t $ft███$d$f7██$t $ft███$d$f7██$t

EOF
}

current() {
    printf '\n'

    for i in 0 1 2 3 4 5 6 8 9 10 11 14; do
        printf '\033[48;5;%sm     \033[m\n' "$i"

        [ "$i" = 0 ] && printf ''
    done

    printf '\n'

    exit
}

case "$@" in
	block)
		block
		;;
	heart)
		current
	;;
esac
