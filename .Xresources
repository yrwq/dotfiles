Xft.autohint: 0
Xft.antialias: 1
Xft.hinting: true
Xft.hintstyle: hintslight
Xft.dpi: 96

*.foreground:   #250e07
*.background:   #f2e5bc
*.cursorColor:  #250e07
*.color0:       #e8d69f
