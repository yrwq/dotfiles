*.color11:      #bea357
*.color4:       #6d93cd
*.color12:      #9ab6e2
*.color5:       #a860d0
*.color13:      #dc7d7b
*.color6:       #68ccbf
*.color14:      #75b1a9
*.color7:       #3e3533
*.color15:      #72635f

