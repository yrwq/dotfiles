Xft.autohint: 0
Xft.antialias: 1
Xft.hinting: true
Xft.hintstyle: hintslight
Xft.dpi: 96

! special
*.foreground:   #e8e8e8
*.background:   #1c1f27
*.cursorColor:  #e8e8e8

! black
*.color0:       #2d323e
*.color8:       #3f444e

! red
*.color1:       #af6266
*.color9:       #ed858a

! green
*.color2:       #5da77e
*.color10:      #85edb3

! yellow
*.color3:       #bb8369
*.color11:      #eda685

! blue
*.color4:       #658bb4
*.color12:      #85b8ed

! magenta
*.color5:       #9d67b8
*.color13:      #ca85ed

! cyan
*.color6:       #66b2b5
*.color14:      #85e8ed

! white
*.color7:       #cfcfcf
*.color15:      #d0bcbc
